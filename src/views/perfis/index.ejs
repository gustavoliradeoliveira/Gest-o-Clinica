<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-size:1.1rem;font-weight:700;">Perfis de Acesso</h2>
        <p class="text-muted fs-sm mb-0"><%= total %> registro(s) encontrado(s)</p>
    </div>
    <% if (usuario && usuario.permissoes && usuario.permissoes.perfis && usuario.permissoes.perfis.criar) { %>
    <a href="/perfis/novo" class="btn btn-primary btn-sm" id="btn-novo-perfil">
        <i class="bi bi-plus-lg me-1"></i>Novo Perfil
    </a>
    <% } %>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="GET" action="/perfis" class="d-flex gap-2 search-form">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="busca" class="form-control" placeholder="Buscar perfil..."
                       value="<%= busca || '' %>">
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm">Buscar</button>
            <% if (busca) { %><a href="/perfis" class="btn btn-outline-secondary btn-sm">Limpar</a><% } %>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th><th>Nome</th><th>Descrição</th><th>Status</th><th>Criado em</th><th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                <% if (!registros.length) { %>
                <tr><td colspan="6" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum perfil encontrado.
                </td></tr>
                <% } %>
                <% registros.forEach(p => { %>
                <tr>
                    <td class="text-muted fs-sm"><%= p.id %></td>
                    <td><strong><%= p.nome %></strong></td>
                    <td class="text-muted fs-sm"><%= p.descricao || '—' %></td>
                    <td>
                        <span class="badge <%= p.ativo ? 'badge-confirmada' : 'badge-cancelada' %> rounded-pill">
                            <%= p.ativo ? 'Ativo' : 'Inativo' %>
                        </span>
                    </td>
                    <td class="text-muted fs-sm"><%= new Date(p.criado_em).toLocaleDateString('pt-BR') %></td>
                    <td class="text-end">
                        <% if (usuario.permissoes.perfis && usuario.permissoes.perfis.editar) { %>
                        <a href="/perfis/<%= p.id %>/editar" class="btn btn-outline-primary btn-sm me-1" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <% } %>
                        <% if (usuario.permissoes.perfis && usuario.permissoes.perfis.deletar) { %>
                        <form action="/perfis/<%= p.id %>/deletar" method="POST"
                              class="form-delete d-inline" data-nome="<%= p.nome %>">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<%- include('../partials/paginacao') %>
