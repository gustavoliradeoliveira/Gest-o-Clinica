<% const acoes = ['criar', 'ler', 'editar', 'deletar']; %>
<% const modulosLabel = {
    usuarios: 'Usuários', perfis: 'Perfis', pacientes: 'Pacientes',
    medicos: 'Médicos', consultas: 'Consultas', prontuarios: 'Prontuários', especialidades: 'Especialidades'
}; %>

<div class="row justify-content-center">
    <div class="col-xl-9">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/perfis" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Editar Perfil: <%= perfil.nome %></h2>
        </div>

        <form action="/perfis/<%= perfil.id %>" method="POST" id="form-edit-perfil">
            <div class="card mb-3">
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label for="nome" class="form-label">Nome <span class="text-danger">*</span></label>
                            <input type="text" id="nome" name="nome" class="form-control"
                                   value="<%= perfil.nome %>" required>
                        </div>
                        <div class="col-md-5">
                            <label for="descricao" class="form-label">Descrição</label>
                            <input type="text" id="descricao" name="descricao" class="form-control"
                                   value="<%= perfil.descricao || '' %>">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Status</label>
                            <select name="ativo" class="form-select" id="status-perfil">
                                <option value="true"  <%= perfil.ativo ? 'selected' : '' %>>Ativo</option>
                                <option value="false" <%= !perfil.ativo ? 'selected' : '' %>>Inativo</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-shield-lock me-2 text-primary"></i>Permissões por Módulo
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 perm-table">
                            <thead>
                                <tr>
                                    <th style="width:35%">Módulo</th>
                                    <th>Criar</th><th>Ler</th><th>Editar</th><th>Deletar</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% modulos.forEach(mod => { %>
                                <% const modPerm = (perfil.permissoes && perfil.permissoes[mod]) || {}; %>
                                <tr>
                                    <td><strong><%= modulosLabel[mod] || mod %></strong></td>
                                    <% acoes.forEach(acao => { %>
                                    <td>
                                        <div class="form-check d-flex justify-content-center">
                                            <input type="checkbox" class="form-check-input"
                                                   id="perm_<%= mod %>_<%= acao %>"
                                                   name="perm_<%= mod %>_<%= acao %>"
                                                   <%= modPerm[acao] ? 'checked' : '' %>>
                                        </div>
                                    </td>
                                    <% }) %>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" id="btn-atualizar-perfil">
                    <i class="bi bi-check-lg me-1"></i>Atualizar
                </button>
                <a href="/perfis" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
