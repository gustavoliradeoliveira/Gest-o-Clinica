<% const acoes = ['criar', 'ler', 'editar', 'deletar']; %>
<% const modulosLabel = {
    usuarios: 'Usuários', perfis: 'Perfis', pacientes: 'Pacientes',
    medicos: 'Médicos', consultas: 'Consultas', prontuarios: 'Prontuários', especialidades: 'Especialidades'
}; %>

<div class="row justify-content-center">
    <div class="col-xl-9">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/perfis" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Novo Perfil de Acesso</h2>
        </div>

        <% if (erros && erros.length) { %>
        <div class="alert alert-danger">
            <% erros.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e.msg %></div><% }) %>
        </div>
        <% } %>

        <form action="/perfis" method="POST" id="form-create-perfil">
            <div class="card mb-3">
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="nome" class="form-label">Nome do Perfil <span class="text-danger">*</span></label>
                            <input type="text" id="nome" name="nome" class="form-control"
                                   placeholder="Ex: Recepcionista" required>
                        </div>
                        <div class="col-md-6">
                            <label for="descricao" class="form-label">Descrição</label>
                            <input type="text" id="descricao" name="descricao" class="form-control"
                                   placeholder="Descrição do perfil...">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Permissões -->
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-shield-lock me-2 text-primary"></i>Permissões por Módulo
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 perm-table">
                            <thead>
                                <tr>
                                    <th style="width:35%">Módulo</th>
                                    <th>Criar</th><th>Ler</th><th>Editar</th><th>Deletar</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% modulos.forEach(mod => { %>
                                <tr>
                                    <td><strong><%= modulosLabel[mod] || mod %></strong></td>
                                    <% acoes.forEach(acao => { %>
                                    <td>
                                        <div class="form-check d-flex justify-content-center">
                                            <input type="checkbox" class="form-check-input"
                                                   id="perm_<%= mod %>_<%= acao %>"
                                                   name="perm_<%= mod %>_<%= acao %>">
                                        </div>
                                    </td>
                                    <% }) %>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" id="btn-salvar-perfil">
                    <i class="bi bi-check-lg me-1"></i>Salvar Perfil
                </button>
                <a href="/perfis" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
