<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/medicos" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Editar Médico</h2>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <form action="/medicos/<%= medico.id %>" method="POST" id="form-edit-medico">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label for="nome" class="form-label">Nome Completo <span class="text-danger">*</span></label>
                            <input type="text" id="nome" name="nome" class="form-control"
                                   value="<%= medico.nome %>" required>
                        </div>
                        <div class="col-md-4">
                            <label for="crm" class="form-label">CRM <span class="text-danger">*</span></label>
                            <input type="text" id="crm" name="crm" class="form-control"
                                   value="<%= medico.crm %>" required>
                        </div>
                        <div class="col-md-6">
                            <label for="especialidade_id" class="form-label">Especialidade</label>
                            <select id="especialidade_id" name="especialidade_id" class="form-select">
                                <option value="">Selecione...</option>
                                <% especialidades.forEach(e => { %>
                                <option value="<%= e.id %>" <%= e.id === medico.especialidade_id ? 'selected' : '' %>>
                                    <%= e.nome %>
                                </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="telefone" class="form-label">Telefone</label>
                            <input type="text" id="telefone" name="telefone" class="form-control"
                                   value="<%= medico.telefone || '' %>">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select name="ativo" class="form-select" id="status-medico">
                                <option value="true"  <%= medico.ativo ? 'selected' : '' %>>Ativo</option>
                                <option value="false" <%= !medico.ativo ? 'selected' : '' %>>Inativo</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="email" class="form-label">E-mail</label>
                            <input type="email" id="email" name="email" class="form-control"
                                   value="<%= medico.email || '' %>">
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary" id="btn-atualizar-medico">
                            <i class="bi bi-check-lg me-1"></i>Atualizar
                        </button>
                        <a href="/medicos" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
