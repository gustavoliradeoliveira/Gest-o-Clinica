<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/medicos" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Novo Médico</h2>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <% if (erros && erros.length) { %>
                <div class="alert alert-danger">
                    <% erros.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e.msg %></div><% }) %>
                </div>
                <% } %>
                <form action="/medicos" method="POST" id="form-create-medico">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label for="nome" class="form-label">Nome Completo <span class="text-danger">*</span></label>
                            <input type="text" id="nome" name="nome" class="form-control" required>
                        </div>
                        <div class="col-md-4">
                            <label for="crm" class="form-label">CRM <span class="text-danger">*</span></label>
                            <input type="text" id="crm" name="crm" class="form-control"
                                   placeholder="CRM-SP 00000" required>
                        </div>
                        <div class="col-md-6">
                            <label for="especialidade_id" class="form-label">Especialidade</label>
                            <select id="especialidade_id" name="especialidade_id" class="form-select">
                                <option value="">Selecione...</option>
                                <% especialidades.forEach(e => { %>
                                <option value="<%= e.id %>"><%= e.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="telefone" class="form-label">Telefone</label>
                            <input type="text" id="telefone" name="telefone" class="form-control"
                                   placeholder="(00) 00000-0000">
                        </div>
                        <div class="col-md-3">
                            <label for="email" class="form-label">E-mail</label>
                            <input type="email" id="email" name="email" class="form-control">
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary" id="btn-salvar-medico">
                            <i class="bi bi-check-lg me-1"></i>Salvar
                        </button>
                        <a href="/medicos" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
