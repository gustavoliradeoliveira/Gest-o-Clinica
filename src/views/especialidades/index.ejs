<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-size:1.1rem;font-weight:700;">Lista de Especialidades</h2>
        <p class="text-muted fs-sm mb-0"><%= total %> registro(s) encontrado(s)</p>
    </div>
    <% if (usuario && usuario.permissoes && usuario.permissoes.especialidades && usuario.permissoes.especialidades.criar) { %>
    <a href="/especialidades/novo" class="btn btn-primary btn-sm" id="btn-nova-especialidade">
        <i class="bi bi-plus-lg me-1"></i>Nova Especialidade
    </a>
    <% } %>
</div>

<!-- Search -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="GET" action="/especialidades" class="d-flex gap-2 align-items-center search-form">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="busca" class="form-control" placeholder="Buscar por nome..."
                       value="<%= busca || '' %>">
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm">Buscar</button>
            <% if (busca) { %><a href="/especialidades" class="btn btn-outline-secondary btn-sm">Limpar</a><% } %>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Descrição</th>
                    <th>Status</th>
                    <th>Criado em</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                <% if (!registros.length) { %>
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                        Nenhuma especialidade encontrada.
                    </td>
                </tr>
                <% } %>
                <% registros.forEach(e => { %>
                <tr>
                    <td class="text-muted fs-sm"><%= e.id %></td>
                    <td><strong><%= e.nome %></strong></td>
                    <td class="text-muted fs-sm"><%= e.descricao || '—' %></td>
                    <td>
                        <% if (e.ativo) { %>
                        <span class="badge badge-confirmada rounded-pill">Ativo</span>
                        <% } else { %>
                        <span class="badge badge-cancelada rounded-pill">Inativo</span>
                        <% } %>
                    </td>
                    <td class="text-muted fs-sm">
                        <%= new Date(e.criado_em).toLocaleDateString('pt-BR') %>
                    </td>
                    <td class="text-end">
                        <% if (usuario && usuario.permissoes && usuario.permissoes.especialidades && usuario.permissoes.especialidades.editar) { %>
                        <a href="/especialidades/<%= e.id %>/editar" class="btn btn-outline-primary btn-sm me-1" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <% } %>
                        <% if (usuario && usuario.permissoes && usuario.permissoes.especialidades && usuario.permissoes.especialidades.deletar) { %>
                        <form action="/especialidades/<%= e.id %>/deletar" method="POST"
                              class="form-delete d-inline" data-nome="<%= e.nome %>">
                            <button type="submit" class="btn btn-outline-danger btn-sm" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/paginacao') %>