<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-size:1.1rem;font-weight:700;">Prontuários</h2>
        <p class="text-muted fs-sm mb-0"><%= total %> registro(s)</p>
    </div>
    <% if (usuario && usuario.permissoes && usuario.permissoes.prontuarios && usuario.permissoes.prontuarios.criar) { %>
    <a href="/prontuarios/novo" class="btn btn-primary btn-sm" id="btn-novo-prontuario">
        <i class="bi bi-plus-lg me-1"></i>Novo Prontuário
    </a>
    <% } %>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="GET" action="/prontuarios" class="d-flex gap-2 search-form">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="busca" class="form-control" placeholder="Buscar por paciente ou médico..."
                       value="<%= busca || '' %>">
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm">Buscar</button>
            <% if (busca) { %><a href="/prontuarios" class="btn btn-outline-secondary btn-sm">Limpar</a><% } %>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>#</th><th>Paciente</th><th>Médico</th><th>Consulta</th><th>Diagnóstico</th><th>Criado em</th><th class="text-end">Ações</th></tr>
            </thead>
            <tbody>
                <% if (!registros.length) { %>
                <tr><td colspan="7" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum prontuário encontrado.
                </td></tr>
                <% } %>
                <% registros.forEach(p => { %>
                <tr>
                    <td class="text-muted fs-sm"><%= p.id %></td>
                    <td><strong><%= p.paciente_nome %></strong></td>
                    <td class="fs-sm"><%= p.medico_nome %></td>
                    <td class="text-muted fs-sm">
                        <%= new Date(p.data_hora).toLocaleDateString('pt-BR') %>
                    </td>
                    <td class="fs-sm"><%= p.diagnostico ? p.diagnostico.substring(0,60) + (p.diagnostico.length > 60 ? '…' : '') : '—' %></td>
                    <td class="text-muted fs-sm"><%= new Date(p.criado_em).toLocaleDateString('pt-BR') %></td>
                    <td class="text-end">
                        <% if (usuario.permissoes.prontuarios && usuario.permissoes.prontuarios.editar) { %>
                        <a href="/prontuarios/<%= p.id %>/editar" class="btn btn-outline-primary btn-sm me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <% } %>
                        <% if (usuario.permissoes.prontuarios && usuario.permissoes.prontuarios.deletar) { %>
                        <form action="/prontuarios/<%= p.id %>/deletar" method="POST"
                              class="form-delete d-inline" data-nome="prontuário #<%= p.id %>">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<%- include('../partials/paginacao') %>