<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/prontuarios" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Novo Prontuário</h2>
        </div>

        <% if (!consultas.length) { %>
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            Nenhuma consulta <strong>realizada</strong> disponível para prontuário.
            <a href="/consultas" class="alert-link">Gerenciar consultas</a>
        </div>
        <% } else { %>

        <div class="card">
            <div class="card-body p-4">
                <form action="/prontuarios" method="POST" id="form-create-prontuario">
                    <div class="mb-3">
                        <label for="consulta_id" class="form-label">Consulta <span class="text-danger">*</span></label>
                        <select id="consulta_id" name="consulta_id" class="form-select" required>
                            <option value="">Selecione a consulta...</option>
                            <% consultas.forEach(c => { %>
                            <option value="<%= c.id %>">
                                #<%= c.id %> — <%= c.paciente_nome %> c/ <%= c.medico_nome %>
                                em <%= new Date(c.data_hora).toLocaleDateString('pt-BR') %>
                            </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="descricao" class="form-label">Descrição / Anamnese <span class="text-danger">*</span></label>
                        <textarea id="descricao" name="descricao" class="form-control" rows="4"
                                  placeholder="Relato do paciente, histórico, exame físico..." required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="diagnostico" class="form-label">Diagnóstico</label>
                        <textarea id="diagnostico" name="diagnostico" class="form-control" rows="3"
                                  placeholder="CID-10 e descrição do diagnóstico..."></textarea>
                    </div>
                    <div class="mb-4">
                        <label for="prescricao" class="form-label">Prescrição</label>
                        <textarea id="prescricao" name="prescricao" class="form-control" rows="3"
                                  placeholder="Medicamentos, dosagens, orientações..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" id="btn-salvar-prontuario">
                            <i class="bi bi-check-lg me-1"></i>Salvar Prontuário
                        </button>
                        <a href="/prontuarios" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
        <% } %>
    </div>
</div>