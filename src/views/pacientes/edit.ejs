<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/pacientes" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Editar Paciente</h2>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <form action="/pacientes/<%= paciente.id %>" method="POST" id="form-edit-paciente">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label for="nome" class="form-label">Nome Completo <span class="text-danger">*</span></label>
                            <input type="text" id="nome" name="nome" class="form-control"
                                   value="<%= paciente.nome %>" required>
                        </div>
                        <div class="col-md-4">
                            <label for="cpf" class="form-label">CPF <span class="text-danger">*</span></label>
                            <input type="text" id="cpf" name="cpf" class="form-control"
                                   value="<%= paciente.cpf %>" required maxlength="14">
                        </div>
                        <div class="col-md-4">
                            <label for="data_nasc" class="form-label">Data de Nascimento <span class="text-danger">*</span></label>
                            <input type="date" id="data_nasc" name="data_nasc" class="form-control"
                                   value="<%= paciente.data_nasc ? paciente.data_nasc.toISOString().split('T')[0] : '' %>" required>
                        </div>
                        <div class="col-md-4">
                            <label for="telefone" class="form-label">Telefone</label>
                            <input type="text" id="telefone" name="telefone" class="form-control"
                                   value="<%= paciente.telefone || '' %>">
                        </div>
                        <div class="col-md-4">
                            <label for="email" class="form-label">E-mail</label>
                            <input type="email" id="email" name="email" class="form-control"
                                   value="<%= paciente.email || '' %>">
                        </div>
                        <div class="col-md-8">
                            <label for="endereco" class="form-label">Endereço</label>
                            <input type="text" id="endereco" name="endereco" class="form-control"
                                   value="<%= paciente.endereco || '' %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select name="ativo" class="form-select" id="status-paciente">
                                <option value="true"  <%= paciente.ativo ? 'selected' : '' %>>Ativo</option>
                                <option value="false" <%= !paciente.ativo ? 'selected' : '' %>>Inativo</option>
                            </select>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary" id="btn-atualizar-paciente">
                            <i class="bi bi-check-lg me-1"></i>Atualizar
                        </button>
                        <a href="/pacientes" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>