<% if (totalPaginas > 1) { %>
<nav aria-label="Paginação" class="mt-3">
    <ul class="pagination pagination-sm justify-content-center mb-0">
        <!-- Anterior -->
        <li class="page-item <%= pagina <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?pagina=<%= pagina - 1 %>&busca=<%= busca || '' %>">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        <% for (let i = Math.max(1, pagina - 2); i <= Math.min(totalPaginas, pagina + 2); i++) { %>
        <li class="page-item <%= i === pagina ? 'active' : '' %>">
            <a class="page-link" href="?pagina=<%= i %>&busca=<%= busca || '' %>"><%= i %></a>
        </li>
        <% } %>

        <!-- Próximo -->
        <li class="page-item <%= pagina >= totalPaginas ? 'disabled' : '' %>">
            <a class="page-link" href="?pagina=<%= pagina + 1 %>&busca=<%= busca || '' %>">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
    <p class="text-center text-muted fs-sm mt-2 mb-0">
        Página <%= pagina %> de <%= totalPaginas %> — <%= total %> registro(s)
    </p>
</nav>
<% } %>
