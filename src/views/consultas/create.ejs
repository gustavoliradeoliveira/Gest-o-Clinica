<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex align-items-center gap-2 mb-4">
            <a href="/consultas" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h2 class="mb-0" style="font-size:1.1rem;font-weight:700;">Nova Consulta</h2>
        </div>
        <div class="card">
            <div class="card-body p-4">
                <% if (erros && erros.length) { %>
                <div class="alert alert-danger">
                    <% erros.forEach(e => { %><div><i class="bi bi-exclamation-circle me-1"></i><%= e.msg %></div><% }) %>
                </div>
                <% } %>
                <form action="/consultas" method="POST" id="form-create-consulta">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="paciente_id" class="form-label">Paciente <span class="text-danger">*</span></label>
                            <select id="paciente_id" name="paciente_id" class="form-select" required>
                                <option value="">Selecione o paciente...</option>
                                <% pacientes.forEach(p => { %>
                                <option value="<%= p.id %>"><%= p.nome %> — <%= p.cpf %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="medico_id" class="form-label">Médico <span class="text-danger">*</span></label>
                            <select id="medico_id" name="medico_id" class="form-select" required>
                                <option value="">Selecione o médico...</option>
                                <% medicos.forEach(m => { %>
                                <option value="<%= m.id %>"><%= m.nome %> — <%= m.crm %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="data_hora" class="form-label">Data e Hora <span class="text-danger">*</span></label>
                            <input type="datetime-local" id="data_hora" name="data_hora" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label for="status" class="form-label">Status</label>
                            <select id="status" name="status" class="form-select">
                                <% statusValidos.forEach(s => { %>
                                <option value="<%= s %>" <%= s === 'agendada' ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-12">
                            <label for="observacoes" class="form-label">Observações</label>
                            <textarea id="observacoes" name="observacoes" class="form-control" rows="3"
                                      placeholder="Motivo da consulta, queixas do paciente..."></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary" id="btn-salvar-consulta">
                            <i class="bi bi-check-lg me-1"></i>Agendar
                        </button>
                        <a href="/consultas" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>