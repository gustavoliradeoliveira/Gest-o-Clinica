<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-size:1.1rem;font-weight:700;">Usuários do Sistema</h2>
        <p class="text-muted fs-sm mb-0"><%= total %> registro(s)</p>
    </div>
    <% if (usuario && usuario.permissoes && usuario.permissoes.usuarios && usuario.permissoes.usuarios.criar) { %>
    <a href="/usuarios/novo" class="btn btn-primary btn-sm" id="btn-novo-usuario">
        <i class="bi bi-plus-lg me-1"></i>Novo Usuário
    </a>
    <% } %>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="GET" action="/usuarios" class="d-flex gap-2 search-form">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="busca" class="form-control" placeholder="Buscar por nome ou e-mail..."
                       value="<%= busca || '' %>">
            </div>
            <button type="submit" class="btn btn-outline-primary btn-sm">Buscar</button>
            <% if (busca) { %><a href="/usuarios" class="btn btn-outline-secondary btn-sm">Limpar</a><% } %>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>#</th><th>Nome</th><th>E-mail</th><th>Perfil</th><th>Status</th><th>Criado em</th><th class="text-end">Ações</th></tr>
            </thead>
            <tbody>
                <% if (!registros.length) { %>
                <tr><td colspan="7" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-4 d-block mb-2"></i>Nenhum usuário encontrado.
                </td></tr>
                <% } %>
                <% registros.forEach(u => { %>
                <tr>
                    <td class="text-muted fs-sm"><%= u.id %></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="sidebar-avatar" style="width:28px;height:28px;font-size:.7rem;">
                                <%= u.nome.charAt(0).toUpperCase() %>
                            </div>
                            <strong><%= u.nome %></strong>
                        </div>
                    </td>
                    <td class="text-muted fs-sm"><%= u.email %></td>
                    <td><span class="badge bg-light text-dark border"><%= u.perfil_nome %></span></td>
                    <td>
                        <span class="badge <%= u.ativo ? 'badge-confirmada' : 'badge-cancelada' %> rounded-pill">
                            <%= u.ativo ? 'Ativo' : 'Inativo' %>
                        </span>
                    </td>
                    <td class="text-muted fs-sm"><%= new Date(u.criado_em).toLocaleDateString('pt-BR') %></td>
                    <td class="text-end">
                        <% if (usuario.permissoes.usuarios && usuario.permissoes.usuarios.editar) { %>
                        <a href="/usuarios/<%= u.id %>/editar" class="btn btn-outline-primary btn-sm me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <% } %>
                        <% if (usuario.permissoes.usuarios && usuario.permissoes.usuarios.deletar && u.id !== usuario.id) { %>
                        <form action="/usuarios/<%= u.id %>/deletar" method="POST"
                              class="form-delete d-inline" data-nome="<%= u.nome %>">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
<%- include('../partials/paginacao') %>
